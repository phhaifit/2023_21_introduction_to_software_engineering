# PostgreSQL connection URL for Prisma
# Example: postgresql://user:password@localhost:5432/virtual_company_dev
DATABASE_URL="postgresql://localhost:5432/virtual_company_dev"

# DATABASE_URL="postgresql://user:password@localhost:5432/virtual_company_dev"
# Directory where agent skill.md files are written
# When set, FileSystemAgentSkillWriter writes to <dir>/<workspaceId>/<agentId>/skill.md
# When unset, NoOpAgentSkillWriter is used (no files written)
# AGENT_SKILLS_DIR="./agent-skills"
# OPENCLAW_AGENT_WORKSPACE_DIR="../../openclaw-agents"
# OPENCLAW_AGENT_MIRROR_CONTAINER="openclaw-openclaw-gateway-1"
# OPENCLAW_AGENT_MIRROR_DIR="/home/node/.openclaw/workspace/openclaw-agents"

# Local KB/RAG upload storage root.
# Optional for local development; defaults to .data/knowledge-base-rag/uploads.
# KNOWLEDGE_FILE_STORAGE_DIR=".data/knowledge-base-rag/uploads"

# Local/demo upload processing mode. When set to "inline", each real upload is
# parsed, chunked, embedded, and indexed before the upload response returns.
# Requires DATABASE_URL plus the embedding and pgvector settings below.
# KNOWLEDGE_INGESTION_MODE="inline"

# OpenAI-compatible KB/RAG embedding provider.
# Required only when real embedding generation is enabled.
# KNOWLEDGE_EMBEDDING_PROVIDER="openai-compatible"
# KNOWLEDGE_EMBEDDING_BASE_URL="https://example-embedding-provider.local/v1"
# KNOWLEDGE_EMBEDDING_API_KEY=
# KNOWLEDGE_EMBEDDING_MODEL="text-embedding-3-small"
# KNOWLEDGE_EMBEDDING_DIMENSIONS=1536
# KNOWLEDGE_EMBEDDING_BATCH_SIZE=32
# KNOWLEDGE_EMBEDDING_TIMEOUT_MS=30000

# PostgreSQL pgvector KB/RAG vector index.
# Uses the primary DATABASE_URL connection.
# KNOWLEDGE_VECTOR_PROVIDER="pgvector"
# KNOWLEDGE_VECTOR_DIMENSIONS=1536
# KNOWLEDGE_VECTOR_DISTANCE="cosine"
# KNOWLEDGE_VECTOR_BATCH_SIZE=64

# Enable only for the opt-in local pgvector smoke test. The smoke test uses
# deterministic 3-dimensional vectors and does not call embedding/RAG providers.
# KNOWLEDGE_PGVECTOR_SMOKE=1
# KNOWLEDGE_VECTOR_PROVIDER="pgvector"
# KNOWLEDGE_VECTOR_DIMENSIONS=3
# KNOWLEDGE_VECTOR_DISTANCE="cosine"

# OpenAI-compatible KB/RAG answer provider.
# Required only when grounded RAG answer generation is enabled.
# KNOWLEDGE_RAG_PROVIDER="openai-compatible"
# KNOWLEDGE_RAG_BASE_URL="https://example-llm-provider.local/v1"
# KNOWLEDGE_RAG_API_KEY=
# KNOWLEDGE_RAG_MODEL="provider-model-name"
# KNOWLEDGE_RAG_TIMEOUT_MS=30000
# KNOWLEDGE_RAG_MAX_OUTPUT_TOKENS=800

# OpenClaw Gateway Security Token
# OPENCLAW_GATEWAY_TOKEN=
# LLM Providers for Agent Management Prompt Assistant
# GEMINI_API_KEY="your_gemini_api_key_here"
# GEMINI_MODEL_ID="gemini-2.5-flash"
# OPENROUTER_API_KEY="your_openrouter_api_key_here"
# OPENROUTER_MODEL_ID="openrouter/owl-alpha"
