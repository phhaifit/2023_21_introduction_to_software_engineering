# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection URL for Prisma.
# Example with user/password:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/virtual_company_dev"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/virtual_company_dev"


# ---------------------------------------------------------------------------
# Agent skill files / OpenClaw workspace mirror
# ---------------------------------------------------------------------------
# Directory where agent skill.md files are written.
# When set, FileSystemAgentSkillWriter writes to <dir>/<workspaceId>/<agentId>/skill.md.
# When unset, NoOpAgentSkillWriter is used.
# AGENT_SKILLS_DIR="./agent-skills"

# Optional OpenClaw local workspace mirror settings.
# OPENCLAW_AGENT_WORKSPACE_DIR="../../openclaw-agents"
# OPENCLAW_AGENT_MIRROR_CONTAINER="openclaw-openclaw-gateway-1"
# OPENCLAW_AGENT_MIRROR_DIR="/home/node/.openclaw/workspace/openclaw-agents"
# OPENCLAW_WORKFLOW_WORKSPACE_DIR="../../openclaw-workflows"
# OPENCLAW_WORKFLOW_MIRROR_CONTAINER="openclaw-openclaw-gateway-1"
# OPENCLAW_WORKFLOW_MIRROR_DIR="/home/node/.openclaw/workspace/openclaw-workflows"


# ---------------------------------------------------------------------------
# OpenClaw gateway
# ---------------------------------------------------------------------------
# Do not commit real tokens.
# OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_URL="http://127.0.0.1:18789"
# Example only; change for your local OS/user.
OPENCLAW_CONFIG_DIR="C:/Users/your-user/.openclaw"


# ---------------------------------------------------------------------------
# Prompt assistant LLM providers
# ---------------------------------------------------------------------------
# Used by Agent Management prompt assistant features.
# Do not commit real API keys.
# GEMINI_API_KEY=
GEMINI_MODEL_ID="gemini-2.5-flash"

# Optional OpenRouter model for prompt assistant features.
# Uses the shared OPENROUTER_API_KEY listed in the KB/RAG embeddings section.
# This model setting is separate from KB/RAG embeddings below.
# OPENROUTER_MODEL_ID="openrouter/owl-alpha"


# ---------------------------------------------------------------------------
# Workflow runtime
# ---------------------------------------------------------------------------
# Timeout for each workflow step execution in milliseconds.
WORKFLOW_STEP_TIMEOUT_MS=600000


# ---------------------------------------------------------------------------
# KB/RAG local upload storage
# ---------------------------------------------------------------------------
# Optional for local development; defaults to .data/knowledge-base-rag/uploads.
# KNOWLEDGE_FILE_STORAGE_DIR=".data/knowledge-base-rag/uploads"


# ---------------------------------------------------------------------------
# KB/RAG local inline ingestion
# ---------------------------------------------------------------------------
# When set to "inline", each real upload is parsed, chunked, embedded,
# and indexed before the upload response returns.
# Required for the local web demo upload -> index -> chat flow.
KNOWLEDGE_INGESTION_MODE="inline"


# ---------------------------------------------------------------------------
# KB/RAG embeddings via OpenRouter
# ---------------------------------------------------------------------------
# OpenRouter provides an OpenAI-compatible embeddings endpoint.
# Model slug on OpenRouter should include the provider prefix.
# Do not commit real API keys.
KNOWLEDGE_EMBEDDING_PROVIDER="openrouter"
KNOWLEDGE_EMBEDDING_BASE_URL="https://openrouter.ai/api/v1"
KNOWLEDGE_EMBEDDING_MODEL="openai/text-embedding-3-small"
KNOWLEDGE_EMBEDDING_DIMENSIONS=1536
KNOWLEDGE_EMBEDDING_BATCH_SIZE=32
KNOWLEDGE_EMBEDDING_TIMEOUT_MS=30000
# OPENROUTER_API_KEY=


# ---------------------------------------------------------------------------
# KB/RAG pgvector vector index
# ---------------------------------------------------------------------------
# Uses the primary DATABASE_URL connection.
# Keep dimensions at 1536 for openai/text-embedding-3-small.
KNOWLEDGE_VECTOR_PROVIDER="pgvector"
KNOWLEDGE_VECTOR_DIMENSIONS=1536
KNOWLEDGE_VECTOR_DISTANCE="cosine"
KNOWLEDGE_VECTOR_BATCH_SIZE=64


# ---------------------------------------------------------------------------
# Optional KB/RAG pgvector smoke test
# ---------------------------------------------------------------------------
# Enable only for the opt-in local pgvector smoke test.
# The smoke test uses deterministic 3-dimensional vectors and does not call
# embedding/RAG providers. Do not use these 3D settings for the web demo.
# KNOWLEDGE_PGVECTOR_SMOKE=1
# KNOWLEDGE_VECTOR_DIMENSIONS=3


# ---------------------------------------------------------------------------
# Optional KB/RAG answer provider
# ---------------------------------------------------------------------------
# Required only when grounded RAG answer generation uses a real LLM provider.
# The current local demo can still verify retrieval/citations without enabling
# this, depending on the existing deterministic composer/bridge behavior.
# KNOWLEDGE_RAG_PROVIDER="openai-compatible"
# KNOWLEDGE_RAG_BASE_URL="https://example-llm-provider.local/v1"
# KNOWLEDGE_RAG_API_KEY=
# KNOWLEDGE_RAG_MODEL="provider-model-name"
# KNOWLEDGE_RAG_TIMEOUT_MS=30000
# KNOWLEDGE_RAG_MAX_OUTPUT_TOKENS=800
