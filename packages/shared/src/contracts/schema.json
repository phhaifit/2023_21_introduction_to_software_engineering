{
  "version": "0.1.0-foundation",
  "capabilities": [
    "authentication",
    "subscription-payment",
    "workspace-management",
    "workspace-user-management",
    "agent-management",
    "tools-integration",
    "workflow-management",
    "task-orchestration",
    "knowledge-base-rag"
  ],
  "idKinds": [
    "userId",
    "sessionId",
    "workspaceId",
    "memberId",
    "agentId",
    "toolId",
    "workflowId",
    "taskId",
    "workId",
    "documentId",
    "subscriptionId",
    "transactionId",
    "eventId",
    "jobId"
  ],
  "roles": ["admin", "editor", "viewer"],
  "plans": {
    "standard": {
      "cpuCores": 2,
      "memoryGb": 4,
      "maxAgents": 10,
      "maxDocuments": 100
    },
    "premium": {
      "cpuCores": 4,
      "memoryGb": 8,
      "maxAgents": 30,
      "maxDocuments": 1000
    }
  },
  "statuses": {
    "workspace": ["pending", "running", "failed", "stopping", "deleted"],
    "agent": ["enabled", "disabled", "deleted"],
    "task": [
      "queued",
      "running",
      "requires_action",
      "succeeded",
      "failed",
      "cancelled"
    ],
    "subscription": [
      "pending",
      "active",
      "expiring_soon",
      "expired",
      "cancelled"
    ],
    "workflow": ["draft", "published", "archived"],
    "knowledgeIndex": ["pending", "ingesting", "ready", "failed"]
  },
  "permissions": [
    "workspace:read",
    "workspace:delete",
    "members:manage",
    "agents:manage",
    "tools:manage",
    "workflows:manage",
    "tasks:run",
    "knowledge:manage",
    "billing:manage"
  ],
  "rolePermissions": {
    "admin": [
      "workspace:read",
      "workspace:delete",
      "members:manage",
      "agents:manage",
      "tools:manage",
      "workflows:manage",
      "tasks:run",
      "knowledge:manage",
      "billing:manage"
    ],
    "editor": [
      "workspace:read",
      "agents:manage",
      "tools:manage",
      "workflows:manage",
      "tasks:run",
      "knowledge:manage"
    ],
    "viewer": ["workspace:read"]
  },
  "events": {
    "subscription.activated": ["eventId", "occurredAt", "userId", "subscriptionId", "plan"],
    "subscription.upgraded": ["eventId", "occurredAt", "userId", "subscriptionId", "fromPlan", "toPlan"],
    "workspace.provisioning_requested": ["eventId", "occurredAt", "workspaceId", "subscriptionId", "plan"],
    "workspace.running": ["eventId", "occurredAt", "workspaceId", "status", "runtimeUrl"],
    "workspace.deleted": ["eventId", "occurredAt", "workspaceId", "deletedBy"],
    "member.invited": ["eventId", "occurredAt", "workspaceId", "email", "role"],
    "agent.created": ["eventId", "occurredAt", "workspaceId", "agentId", "status"],
    "agent.updated": ["eventId", "occurredAt", "workspaceId", "agentId", "status"],
    "tool.connected": ["eventId", "occurredAt", "workspaceId", "toolId", "provider"],
    "workflow.published": ["eventId", "occurredAt", "workspaceId", "workflowId"],
    "task.submitted": ["eventId", "occurredAt", "workspaceId", "taskId", "submittedBy"],
    "task.completed": ["eventId", "occurredAt", "workspaceId", "taskId", "status"],
    "knowledge.document_uploaded": ["eventId", "occurredAt", "workspaceId", "documentId", "uploadedBy"],
    "knowledge.index_ready": ["eventId", "occurredAt", "workspaceId", "documentId", "status"],
    "knowledge.document.uploadValidated": ["eventId", "occurredAt", "eventType", "workspaceId", "actorId", "status", "acceptedCount", "rejectedCount"],
    "knowledge.document.ingestionQueued": ["eventId", "occurredAt", "eventType", "workspaceId", "actorId", "documentId", "jobId", "status"],
    "knowledge.document.ingestionStarted": ["eventId", "occurredAt", "eventType", "workspaceId", "documentId", "jobId", "status"],
    "knowledge.document.ingestionCompleted": ["eventId", "occurredAt", "eventType", "workspaceId", "documentId", "jobId", "status", "chunkCount", "indexedChunkCount"],
    "knowledge.document.ingestionFailed": ["eventId", "occurredAt", "eventType", "workspaceId", "documentId", "jobId", "status", "errorCode", "errorMessage"],
    "knowledge.dataSource.connected": ["eventId", "occurredAt", "eventType", "workspaceId", "actorId", "sourceId", "status"],
    "knowledge.dataSource.connectionFailed": ["eventId", "occurredAt", "eventType", "workspaceId", "actorId", "sourceId", "status", "errorCode", "errorMessage"],
    "knowledge.sync.scopeUpdated": ["eventId", "occurredAt", "eventType", "workspaceId", "actorId", "sourceId", "selectedScopeNodeCount"],
    "knowledge.sync.requested": ["eventId", "occurredAt", "eventType", "workspaceId", "actorId", "jobId", "sourceId", "status"],
    "knowledge.sync.started": ["eventId", "occurredAt", "eventType", "workspaceId", "jobId", "sourceId", "status"],
    "knowledge.sync.completed": ["eventId", "occurredAt", "eventType", "workspaceId", "jobId", "sourceId", "status", "scannedItemCount", "changedItemCount"],
    "knowledge.sync.failed": ["eventId", "occurredAt", "eventType", "workspaceId", "jobId", "sourceId", "status", "errorCode", "errorMessage"]
  },
  "api": {
    "successShape": ["ok", "data", "meta"],
    "errorShape": ["ok", "error", "meta"],
    "metaShape": ["requestId", "timestamp"],
    "paginationShape": [
      "page",
      "pageSize",
      "totalItems",
      "totalPages",
      "hasNextPage",
      "hasPreviousPage"
    ],
    "validationIssueShape": ["path", "message", "code"],
    "authenticationErrorCodes": [
      "auth.unauthorized",
      "auth.invalid_credentials",
      "auth.session_expired"
    ],
    "authorizationErrorCodes": ["auth.forbidden"],
    "errorCodes": [
      "auth.unauthorized",
      "auth.invalid_credentials",
      "auth.session_expired",
      "auth.forbidden",
      "validation.invalid_input",
      "workspace.not_found",
      "workspace.not_ready",
      "subscription.required",
      "subscription.payment_failed",
      "agent.not_available",
      "tool.secret_unavailable",
      "workflow.invalid_definition",
      "task.execution_failed",
      "knowledge.access_denied",
      "system.unexpected_error"
    ]
  },
  "contractConventions": {
    "sharedContractScope": [
      "ids",
      "roles",
      "statuses",
      "plans",
      "events",
      "api",
      "publicSummaries",
      "crossModuleRequests"
    ],
    "requestBodyForbiddenFields": [
      "workspaceId",
      "submittedByUserId",
      "userId",
      "createdAt",
      "updatedAt",
      "status",
      "taskId",
      "workId"
    ],
    "secretFieldNameFragments": [
      "secret",
      "password",
      "token",
      "credential",
      "privateKey",
      "hash",
      "apiKey"
    ],
    "forbiddenSharedContractImports": [
      "@vcp/backend",
      "@vcp/database",
      "@vcp/workers",
      "apps/backend",
      "apps/frontend",
      "apps/workers",
      "packages/database",
      "@prisma",
      "PrismaClient",
      "express",
      "react"
    ],
    "forbiddenFrontendCrossModuleImports": [
      "@vcp/backend",
      "@vcp/database",
      "@vcp/workers",
      "apps/backend",
      "apps/workers",
      "packages/database",
      "@prisma",
      "PrismaClient"
    ]
  },
  "taskOrchestration": {
    "routingModes": [
      "auto",
      "specific-agent",
      "predefined-workflow"
    ],
    "runtimeActivityKinds": [
      "routing",
      "workflow",
      "tool",
      "tool-call",
      "web-search",
      "document-read",
      "file-read",
      "browser",
      "shell",
      "api-call",
      "sub-agent",
      "handoff",
      "review",
      "aggregation",
      "completion",
      "message",
      "provider-diagnostic"
    ],
    "createTaskRequestFields": ["prompt", "routing"],
    "createTaskResponseFields": [
      "taskId",
      "workId",
      "status",
      "createdAt"
    ]
  },
  "workspaceManagement": {
    "dtoExports": [
      "WorkspaceSummaryDto",
      "WorkspaceDetailDto",
      "CreateWorkspaceRequest",
      "WorkspaceDeleteAckDto"
    ],
    "routes": [
      { "method": "GET",    "path": "/api/workspaces",                "auth": "authenticated" },
      { "method": "POST",   "path": "/api/workspaces",                "auth": "authenticated" },
      { "method": "GET",    "path": "/api/workspaces/:workspaceId",   "auth": "workspace-member" },
      { "method": "DELETE", "path": "/api/workspaces/:workspaceId",   "auth": "workspace:delete" }
    ],
    "domainEvents": [
      "workspace.provisioning_requested",
      "workspace.running",
      "workspace.deleted"
    ]
  },
  "agentManagement": {
    "skillMarkdownSections": [
      "Role",
      "Model",
      "Responsibilities",
      "Operating Context",
      "Instructions",
      "Requested Tools",
      "Requested Knowledge",
      "Constraints",
      "Escalation Rules",
      "Example Tasks"
    ],
    "dtoExports": [
      "AgentPublicSummary",
      "AgentSkillDraftInput",
      "AgentSkillPreviewRequest",
      "AgentSkillPreviewResponse",
      "AgentSkillImportAnalysisRequest",
      "AgentSkillImportValidationResponse",
      "AgentModelCatalogEntry",
      "AgentDraftProviderMetadata",
      "AgentDraftValidationWarning",
      "AgentCreationAssistantDraft",
      "AgentCreationAssistantDraftRequest",
      "AgentCreationAssistantDraftResponse",
      "AgentRuntimeConfiguration",
      "AgentRuntimeMaterializationHints",
      "AgentRuntimeProfile"
    ],
    "requestDtoExports": [
      "AgentSkillPreviewRequest",
      "AgentSkillImportAnalysisRequest",
      "AgentCreationAssistantDraftRequest"
    ]
  },
  "knowledgeBaseRag": {
    "routes": [
      { "method": "GET", "path": "/api/workspaces/:workspaceId/knowledge/documents" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/uploads" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/uploads/validate" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/uploads/prepare" },
      { "method": "GET", "path": "/api/workspaces/:workspaceId/knowledge/ingestion-jobs" },
      { "method": "GET", "path": "/api/workspaces/:workspaceId/knowledge/data-sources" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/data-sources/:sourceId/connect" },
      { "method": "GET", "path": "/api/workspaces/:workspaceId/knowledge/sync-scope" },
      { "method": "PUT", "path": "/api/workspaces/:workspaceId/knowledge/sync-scope" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/sync-jobs" },
      { "method": "GET", "path": "/api/workspaces/:workspaceId/knowledge/sync-jobs" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/retrieval/search" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/rag/answer" },
      { "method": "GET", "path": "/api/workspaces/:workspaceId/knowledge/agents/:agentId/documents" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/agents/:agentId/documents/:documentId" },
      { "method": "DELETE", "path": "/api/workspaces/:workspaceId/knowledge/agents/:agentId/documents/:documentId" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/agents/:agentId/ask" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/data-sources/google-drive/connect/start" },
      { "method": "GET", "path": "/api/workspaces/:workspaceId/knowledge/data-sources/google-drive/oauth/callback" },
      { "method": "POST", "path": "/api/workspaces/:workspaceId/knowledge/data-sources/:sourceId/disconnect" },
      { "method": "PUT", "path": "/api/workspaces/:workspaceId/knowledge/data-sources/:sourceId/google-drive/scope" },
      { "method": "PUT", "path": "/api/workspaces/:workspaceId/knowledge/data-sources/:sourceId/google-drive/auto-sync" },
      { "method": "GET", "path": "/api/workspaces/:workspaceId/knowledge/sync-jobs/:jobId" }
    ],
    "dtoExports": [
      "KnowledgeDocumentDto",
      "KnowledgeDocumentChunkDto",
      "UploadCandidateFileDto",
      "UploadValidationRequest",
      "UploadValidationResponse",
      "PrepareUploadRequest",
      "PrepareUploadResponse",
      "IngestionJobDto",
      "KnowledgeDataSourceDto",
      "SyncScopeNodeDto",
      "SyncJobDto",
      "GoogleDriveOAuthStartRequest",
      "GoogleDriveOAuthStartResponse",
      "GoogleDriveOAuthCallbackResponse",
      "GoogleDriveSyncScopeRequest",
      "GoogleDriveAutoSyncSettingsRequest",
      "KnowledgeRetrievalSearchRequest",
      "KnowledgeEvidenceDto",
      "KnowledgeRetrievalSearchResponse",
      "KnowledgeRagAnswerRequest",
      "KnowledgeRagAnswerCitationDto",
      "KnowledgeRagAnswerResponse",
      "AgentKnowledgeDocumentDto",
      "AgentKnowledgeAskRequest",
      "AgentKnowledgeAskResponse",
      "KnowledgeBaseApiError"
    ],
    "requestDtoExports": [
      "UploadValidationRequest",
      "PrepareUploadRequest",
      "ConnectKnowledgeDataSourceRequest",
      "UpdateSyncScopeRequest",
      "RequestKnowledgeSyncJobRequest",
      "GoogleDriveOAuthStartRequest",
      "GoogleDriveSyncScopeRequest",
      "GoogleDriveAutoSyncSettingsRequest",
      "KnowledgeRetrievalSearchRequest",
      "KnowledgeRagAnswerRequest",
      "AgentKnowledgeAskRequest"
    ],
    "domainEvents": [
      "knowledge.document.uploadValidated",
      "knowledge.document.ingestionQueued",
      "knowledge.document.ingestionStarted",
      "knowledge.document.ingestionCompleted",
      "knowledge.document.ingestionFailed",
      "knowledge.dataSource.connected",
      "knowledge.dataSource.connectionFailed",
      "knowledge.sync.scopeUpdated",
      "knowledge.sync.requested",
      "knowledge.sync.started",
      "knowledge.sync.completed",
      "knowledge.sync.failed"
    ]
  }
}
