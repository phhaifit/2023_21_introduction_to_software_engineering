generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId    String @id
  email     String @unique
  status    String @default("active")
  createdAt String
  updatedAt String

  @@index([status])
  @@map("users")
}

model Workspace {
  workspaceId String @id
  userId      String
  name        String
  status      String @default("pending")
  createdAt   String
  updatedAt   String

  @@index([userId])
  @@index([status])
  @@map("workspaces")
}

model WorkspaceMember {
  memberId    String @id
  workspaceId String
  userId      String
  role        String
  status      String @default("active")
  createdAt   String
  updatedAt   String

  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, status])
  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Invitation {
  invitationId    String @id
  workspaceId     String
  email           String
  role            String
  status          String @default("pending")
  invitedByUserId String
  createdAt       String
  updatedAt       String

  @@index([workspaceId])
  @@index([invitedByUserId])
  @@index([workspaceId, status])
  @@unique([workspaceId, email, status])
  @@map("invitations")
}

model Agent {
  agentId      String @id
  workspaceId  String
  name         String
  role         String
  model        String
  instructions String
  status       String @default("enabled")
  createdAt    String
  updatedAt    String

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@unique([workspaceId, name])
  @@map("agents")
}

model Subscription {
  subscriptionId String  @id
  userId         String
  workspaceId    String?
  plan           String
  status         String
  expiresAt      String
  createdAt      String
  updatedAt      String

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@map("subscriptions")
}

model Transaction {
  transactionId  String @id
  subscriptionId String
  amount         Float
  currency       String @default("USD")
  status         String
  createdAt      String
  updatedAt      String

  @@index([subscriptionId])
  @@index([status])
  @@map("transactions")
}

model Tool {
  toolId      String @id
  workspaceId String
  name        String
  provider    String
  type        String
  status      String @default("available")
  createdAt   String
  updatedAt   String

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("tools")
}

model ToolConnection {
  toolConnectionId String @id
  workspaceId      String
  toolId           String
  status           String @default("connected")
  createdAt        String
  updatedAt        String

  @@index([workspaceId])
  @@index([toolId])
  @@index([workspaceId, status])
  @@unique([workspaceId, toolId])
  @@map("tool_connections")
}

model AgentToolAssignment {
  assignmentId String @id
  workspaceId  String
  agentId      String
  toolId       String
  status       String @default("active")
  createdAt    String
  updatedAt    String

  @@index([workspaceId])
  @@index([agentId])
  @@index([toolId])
  @@index([workspaceId, status])
  @@unique([workspaceId, agentId, toolId])
  @@map("agent_tool_assignments")
}

model Workflow {
  workflowId  String @id
  workspaceId String
  name        String
  status      String @default("draft")
  createdAt   String
  updatedAt   String

  steps         WorkflowStep[]
  executions    WorkflowExecution[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("workflows")
}

model WorkflowStep {
  workflowStepId String   @id
  workspaceId    String
  workflowId     String
  agentId        String
  stepOrder      Int
  createdAt      String
  updatedAt      String

  workflow      Workflow @relation(fields: [workflowId], references: [workflowId])
  logs          WorkflowStepLog[]

  @@index([workspaceId])
  @@index([workflowId])
  @@index([agentId])
  @@unique([workflowId, stepOrder])
  @@map("workflow_steps")
}

model WorkflowExecution {
  executionId   String   @id
  workspaceId   String
  workflowId    String
  status        String   @default("Pending")
  triggeredBy   String
  startedAt     String
  completedAt   String?

  workflow      Workflow @relation(fields: [workflowId], references: [workflowId])
  logs          WorkflowStepLog[]

  @@index([workspaceId])
  @@index([workflowId])
  @@map("workflow_executions")
}

model WorkflowStepLog {
  logId           String   @id
  workspaceId     String
  executionId     String
  workflowStepId  String
  status          String
  inputData       Json?
  outputData      Json?
  errorMsg        String?
  startedAt       String
  completedAt     String?

  execution     WorkflowExecution @relation(fields: [executionId], references: [executionId])
  step          WorkflowStep      @relation(fields: [workflowStepId], references: [workflowStepId])

  @@index([workspaceId])
  @@index([executionId])
  @@index([workflowStepId])
  @@map("workflow_step_logs")
}

model Task {
  taskId            String  @id
  workspaceId       String
  submittedByUserId String
  routingMode       String
  agentId           String?
  workflowId        String?
  status            String  @default("queued")
  createdAt         String
  updatedAt         String

  @@index([workspaceId])
  @@index([submittedByUserId])
  @@index([agentId])
  @@index([workflowId])
  @@index([workspaceId, status])
  @@map("tasks")
}

model TaskRun {
  taskRunId   String  @id
  workspaceId String
  taskId      String
  jobId       String?
  status      String  @default("queued")
  startedAt   String?
  completedAt String?
  createdAt   String
  updatedAt   String

  @@index([workspaceId])
  @@index([taskId])
  @@index([jobId])
  @@index([workspaceId, status])
  @@unique([jobId])
  @@map("task_runs")
}

model Document {
  documentId       String @id
  workspaceId      String
  uploadedByUserId String
  fileName         String
  status           String @default("pending")
  createdAt        String
  updatedAt        String

  @@index([workspaceId])
  @@index([uploadedByUserId])
  @@index([workspaceId, status])
  @@map("documents")
}

model KnowledgeIndex {
  knowledgeIndexId String @id
  workspaceId       String
  documentId        String
  status            String @default("pending")
  createdAt         String
  updatedAt         String

  @@index([workspaceId])
  @@index([documentId])
  @@index([workspaceId, status])
  @@map("knowledge_indexes")
}

model KnowledgeAccessGrant {
  knowledgeAccessGrantId String @id
  workspaceId             String
  documentId              String
  agentId                 String
  status                  String @default("active")
  createdAt               String
  updatedAt               String

  @@index([workspaceId])
  @@index([documentId])
  @@index([agentId])
  @@index([workspaceId, status])
  @@unique([workspaceId, documentId, agentId])
  @@map("knowledge_access_grants")
}

model Job {
  jobId       String  @id
  workspaceId String?
  userId      String?
  type        String
  status      String  @default("queued")
  createdAt   String
  updatedAt   String

  @@index([workspaceId])
  @@index([userId])
  @@index([status])
  @@map("jobs")
}
