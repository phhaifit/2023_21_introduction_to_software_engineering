generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId       String @id
  email        String @unique
  status       String @default("active")
  passwordHash String
  createdAt    String
  updatedAt    String

  @@index([status])
  @@map("users")
}

model Session {
  sessionId String  @id
  userId    String
  tokenHash String
  createdAt String
  expiresAt String
  revokedAt String?

  @@unique([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Workspace {
  workspaceId                  String  @id
  userId                       String
  createdByUserId              String
  name                         String
  normalizedName               String
  status                       String  @default("provisioning")
  lifecycleVersion             Int     @default(1)
  eventSequence                Int     @default(0)
  ownerBootstrapState          String  @default("not_applicable")
  ownerBootstrapAttemptId      String?
  ownerBootstrapAttemptVersion Int     @default(0)
  ownerBootstrapRequestedAt    String?
  ownerBootstrapExpiresAt      String?
  ownerMembershipEstablishedAt String?
  ownerBootstrapFailureCode    String?
  ownerBootstrapFailureMessage String?
  requestedProfile             String?
  resolvedProvisioningProfile  Json?
  provisioningProfileSource    String  @default("legacy_unknown")
  migrationOrigin              String  @default("legacy_import")
  runtimeVerificationState     String  @default("unknown")
  provider                     String?
  runtimeRef                   String?
  runtimeUrl                   String?
  provisioningRequestedAt      String?
  provisionedAt                String?
  deletionRequestedAt          String?
  deletedAt                    String?
  failureCode                  String?
  failureMessage               String?
  createdAt                    String
  updatedAt                    String

  provisioningOperations WorkspaceProvisioningOperation[]
  commandReceipts        WorkspaceCommandReceipt[]
  visibilityProjections  WorkspaceVisibilityProjection[]

  @@index([userId])
  @@index([createdByUserId])
  @@index([status])
  @@index([status, updatedAt, workspaceId])
  @@index([createdByUserId, ownerBootstrapState, ownerBootstrapExpiresAt, updatedAt, workspaceId])
  @@index([provider])
  @@index([runtimeRef])
  @@index([migrationOrigin])
  @@index([runtimeVerificationState])
  @@map("workspaces")
}

model WorkspaceProvisioningOperation {
  operationId              String  @id
  workspaceId              String
  operationType            String
  operationFamily          String
  status                   String  @default("queued")
  executionPhase           String  @default("queued")
  requestFingerprint       String
  idempotencyKeyHash       String?
  provider                 String?
  providerRequestKey       String
  runtimeRef               String?
  runtimeFinalityProof     String  @default("unknown")
  dependsOnOperationId     String?
  supersedesOperationId    String?
  cancellationRequestedAt  String?
  claimedByWorkerId        String?
  leaseToken               String?
  leaseExpiresAt           String?
  attemptCount             Int     @default(0)
  maxAttempts              Int     @default(5)
  nextAttemptAt            String?
  lastAttemptAt            String?
  lastErrorCode            String?
  lastErrorMessage         String?
  unknownOutcomeAt         String?
  reconciliationRequiredAt String?
  completedAt              String?
  failedAt                 String?
  createdAt                String
  updatedAt                String
  version                  Int     @default(1)

  workspace Workspace @relation(fields: [workspaceId], references: [workspaceId], onDelete: Restrict, onUpdate: NoAction)

  @@unique([providerRequestKey])
  @@index([workspaceId])
  @@index([workspaceId, operationFamily, status])
  @@index([status, nextAttemptAt, leaseExpiresAt])
  @@index([dependsOnOperationId])
  @@index([supersedesOperationId])
  @@index([leaseExpiresAt])
  @@map("workspace_provisioning_operations")
}

model OutboxMessage {
  outboxMessageId  String  @id
  eventId          String
  aggregateType    String
  aggregateId      String
  eventType        String
  eventVersion     Int     @default(1)
  eventSequence    Int
  lifecycleVersion Int?
  payload          Json
  status           String  @default("pending")
  attemptCount     Int     @default(0)
  maxAttempts      Int     @default(10)
  nextAttemptAt    String?
  lastAttemptAt    String?
  publishedAt      String?
  deadLetteredAt   String?
  lastErrorCode    String?
  lastErrorMessage String?
  leaseToken       String?
  leaseExpiresAt   String?
  createdAt        String
  updatedAt        String
  version          Int     @default(1)

  @@unique([eventId])
  @@unique([aggregateType, aggregateId, eventSequence])
  @@index([status, nextAttemptAt, leaseExpiresAt])
  @@index([aggregateType, aggregateId, eventSequence])
  @@index([leaseExpiresAt])
  @@map("outbox_messages")
}

model WorkspaceCommandReceipt {
  commandReceiptId   String  @id
  actorUserId        String
  commandType        String
  commandTarget      String
  workspaceId        String
  idempotencyKeyHash String
  requestFingerprint String
  responseStatusCode Int?
  responseBody       Json?
  responseHeaders    Json?
  operationId        String?
  status             String  @default("pending")
  createdAt          String
  updatedAt          String
  expiresAt          String
  completedAt        String?

  workspace Workspace @relation(fields: [workspaceId], references: [workspaceId], onDelete: Restrict, onUpdate: NoAction)

  @@unique([actorUserId, commandType, commandTarget, idempotencyKeyHash], map: "wcr_idem_scope_key")
  @@index([actorUserId, commandType, commandTarget], map: "wcr_scope_lookup_idx")
  @@index([workspaceId], map: "wcr_workspace_idx")
  @@index([operationId], map: "wcr_operation_idx")
  @@index([expiresAt], map: "wcr_expires_idx")
  @@map("workspace_command_receipts")
}

model WorkspaceVisibilityProjection {
  projectionId        String  @id
  userId              String
  workspaceId         String
  canRead             Boolean @default(false)
  canDelete           Boolean @default(false)
  membershipVersion   Int     @default(0)
  projectionUpdatedAt String
  createdAt           String
  updatedAt           String

  workspace Workspace @relation(fields: [workspaceId], references: [workspaceId], onDelete: Restrict, onUpdate: NoAction)

  @@unique([userId, workspaceId])
  @@index([userId, canRead, projectionUpdatedAt, workspaceId])
  @@index([workspaceId])
  @@map("workspace_visibility_projections")
}

model ProcessedDomainEvent {
  consumerName  String
  eventId       String
  eventType     String
  aggregateType String
  aggregateId   String
  processedAt   String
  resultStatus  String
  createdAt     String
  updatedAt     String

  @@id([consumerName, eventId])
  @@index([consumerName])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@map("processed_domain_events")
}

model WorkspaceMember {
  memberId    String @id
  workspaceId String
  userId      String
  role        String
  status      String @default("active")
  createdAt   String
  updatedAt   String

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, status])
  @@map("workspace_members")
}

model Invitation {
  invitationId    String @id
  workspaceId     String
  email           String
  role            String
  status          String @default("pending")
  invitedByUserId String
  createdAt       String
  updatedAt       String

  @@unique([workspaceId, email, status])
  @@index([workspaceId])
  @@index([invitedByUserId])
  @@index([workspaceId, status])
  @@map("invitations")
}

model Agent {
  agentId      String @id
  workspaceId  String
  name         String
  role         String
  model        String
  instructions String
  status       String @default("enabled")
  createdAt    String
  updatedAt    String

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("agents")
}

model Subscription {
  subscriptionId String  @id
  userId         String
  workspaceId    String?
  plan           String
  status         String
  expiresAt      String
  createdAt      String
  updatedAt      String
  autoRenew      Boolean? @default(true)

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@map("subscriptions")
}

model Transaction {
  transactionId  String @id
  subscriptionId String
  amount         Float
  currency       String @default("USD")
  status         String
  createdAt      String
  updatedAt      String

  @@index([subscriptionId])
  @@index([status])
  @@map("transactions")
}

model Tool {
  toolId      String @id
  workspaceId String
  name        String
  provider    String
  type        String
  status      String @default("available")
  createdAt   String
  updatedAt   String

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("tools")
}

model ToolConnection {
  toolConnectionId String @id
  workspaceId      String
  toolId           String
  status           String @default("connected")
  createdAt        String
  updatedAt        String

  @@unique([workspaceId, toolId])
  @@index([workspaceId])
  @@index([toolId])
  @@index([workspaceId, status])
  @@map("tool_connections")
}

model AgentToolAssignment {
  assignmentId String @id
  workspaceId  String
  agentId      String
  toolId       String
  status       String @default("active")
  createdAt    String
  updatedAt    String

  @@unique([workspaceId, agentId, toolId])
  @@index([workspaceId])
  @@index([agentId])
  @@index([toolId])
  @@index([workspaceId, status])
  @@map("agent_tool_assignments")
}

model Workflow {
  workflowId  String @id
  workspaceId String
  name        String
  description   String?
  status        String @default("published")
  triggerType   String @default("manual")
  triggerConfig Json?
  version       Int    @default(1)
  parentWorkflowId String?
  createdAt     String
  updatedAt   String

  steps      WorkflowStep[]
  executions WorkflowExecution[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([parentWorkflowId])
  @@map("workflows")
}

model WorkflowStep {
  workflowStepId String @id
  workspaceId    String
  workflowId     String
  agentId        String?
  stepType       String   @default("agent")
  stepOrder      Int
  nextSteps      Json?
  inputMapping   Json?
  createdAt      String
  updatedAt      String

  workflow Workflow          @relation(fields: [workflowId], references: [workflowId])
  logs     WorkflowStepLog[]

  @@unique([workflowId, stepOrder])
  @@index([workspaceId])
  @@index([workflowId])
  @@index([agentId])
  @@map("workflow_steps")
}

model WorkflowExecution {
  executionId String  @id
  workspaceId String
  workflowId  String
  status      String  @default("Pending")
  triggeredBy String
  startedAt   String
  completedAt String?

  workflow Workflow          @relation(fields: [workflowId], references: [workflowId])
  logs     WorkflowStepLog[]

  @@index([workspaceId])
  @@index([workflowId])
  @@map("workflow_executions")
}

model WorkflowStepLog {
  logId          String  @id
  workspaceId    String
  executionId    String
  workflowStepId String
  status         String
  inputData      Json?
  outputData     Json?
  errorMsg       String?
  startedAt      String
  completedAt    String?

  execution WorkflowExecution @relation(fields: [executionId], references: [executionId])
  step      WorkflowStep      @relation(fields: [workflowStepId], references: [workflowStepId])

  @@index([workspaceId])
  @@index([executionId])
  @@index([workflowStepId])
  @@map("workflow_step_logs")
}

model Task {
  taskId            String  @id
  workspaceId       String
  submittedByUserId String
  prompt            String
  routingMode       String
  agentId           String?
  workflowId        String?
  status            String  @default("queued")
  createdAt         String
  updatedAt         String

  runs TaskRun[]

  @@unique([workspaceId, taskId])
  @@index([workspaceId])
  @@index([submittedByUserId])
  @@index([agentId])
  @@index([workflowId])
  @@index([workspaceId, status])
  @@map("tasks")
}

model TaskRun {
  taskRunId          String  @id
  workspaceId        String
  taskId             String
  jobId              String?
  status             String  @default("queued")
  attemptNumber      Int
  resolvedAgentId    String?
  resolvedWorkflowId String?
  result             Json?
  errorCode          String?
  errorMessage       String?
  queuedAt           String
  startedAt          String?
  completedAt        String?
  createdAt          String
  updatedAt          String

  task Task @relation(fields: [workspaceId, taskId], references: [workspaceId, taskId], onDelete: Restrict, onUpdate: NoAction)

  @@unique([taskId, attemptNumber])
  @@unique([jobId])
  @@index([workspaceId])
  @@index([taskId])
  @@index([jobId])
  @@index([workspaceId, status])
  @@index([workspaceId, taskId])
  @@map("task_runs")
}

model Document {
  documentId        String  @id
  workspaceId       String
  uploadedByUserId  String
  displayName       String
  fileName          String
  mimeType          String  @default("application/octet-stream")
  fileType          String  @default("unknown")
  sizeBytes         Int     @default(0)
  sourceType        String  @default("upload")
  sourceId          String?
  storageKey        String?
  contentHash       String?
  status            String  @default("pending")
  ingestionStatus   String  @default("pending")
  indexingStatus    String  @default("pending")
  chunkCount        Int     @default(0)
  indexedChunkCount Int     @default(0)
  deletedAt         String?
  createdAt         String
  updatedAt         String

  source        KnowledgeDataSource?     @relation(fields: [sourceId], references: [sourceId], onDelete: Restrict, onUpdate: NoAction)
  indexes       KnowledgeIndex[]
  chunks        KnowledgeDocumentChunk[]
  ingestionJobs KnowledgeIngestionJob[]
  accessGrants  KnowledgeAccessGrant[]

  @@index([workspaceId])
  @@index([uploadedByUserId])
  @@index([sourceId])
  @@index([workspaceId, sourceType])
  @@index([workspaceId, status])
  @@index([workspaceId, ingestionStatus])
  @@index([workspaceId, indexingStatus])
  @@index([workspaceId, contentHash])
  @@map("documents")
}

model KnowledgeIndex {
  knowledgeIndexId  String  @id
  workspaceId       String
  documentId        String
  status            String  @default("pending")
  chunkCount        Int     @default(0)
  indexedChunkCount Int     @default(0)
  lastIndexedAt     String?
  errorCode         String?
  errorMessage      String?
  createdAt         String
  updatedAt         String

  document Document @relation(fields: [documentId], references: [documentId], onDelete: Restrict, onUpdate: NoAction)

  @@index([workspaceId])
  @@index([documentId])
  @@index([workspaceId, status])
  @@map("knowledge_indexes")
}

model KnowledgeDocumentChunk {
  chunkId         String  @id
  workspaceId     String
  documentId      String
  chunkIndex      Int
  contentText     String
  contentHash     String?
  tokenCount      Int?
  embeddingStatus String  @default("pending")
  vectorRef       String?
  sourceLocator   String?
  createdAt       String
  updatedAt       String

  document Document @relation(fields: [documentId], references: [documentId], onDelete: Restrict, onUpdate: NoAction)

  @@unique([documentId, chunkIndex])
  @@index([workspaceId])
  @@index([documentId])
  @@index([workspaceId, embeddingStatus])
  @@index([workspaceId, contentHash])
  @@map("knowledge_document_chunks")
}

model KnowledgeIngestionJob {
  jobId             String  @id
  workspaceId       String
  documentId        String?
  status            String  @default("pending")
  progress          Int     @default(0)
  queuedAt          String
  startedAt         String?
  completedAt       String?
  failedAt          String?
  errorCode         String?
  errorMessage      String?
  requestedByUserId String?
  createdAt         String
  updatedAt         String

  document Document? @relation(fields: [documentId], references: [documentId], onDelete: Restrict, onUpdate: NoAction)

  @@index([workspaceId])
  @@index([documentId])
  @@index([requestedByUserId])
  @@index([workspaceId, status])
  @@map("knowledge_ingestion_jobs")
}

model KnowledgeDataSource {
  sourceId          String  @id
  workspaceId       String
  provider          String
  displayName       String
  connectionStatus  String  @default("not_connected")
  lastSyncAt        String?
  connectedByUserId String?
  safeMetadata      Json?
  createdAt         String
  updatedAt         String

  documents      Document[]
  syncScopeNodes KnowledgeSyncScopeNode[]
  syncJobs       KnowledgeSyncJob[]

  @@index([workspaceId])
  @@index([workspaceId, provider])
  @@index([workspaceId, connectionStatus])
  @@index([connectedByUserId])
  @@map("knowledge_data_sources")
}

model KnowledgeSyncScopeNode {
  scopeNodeId       String  @id
  workspaceId       String
  sourceId          String
  parentScopeNodeId String?
  externalId        String
  nodeType          String
  displayName       String
  selected          Boolean @default(false)
  safeMetadata      Json?
  createdAt         String
  updatedAt         String

  dataSource KnowledgeDataSource @relation(fields: [sourceId], references: [sourceId], onDelete: Restrict, onUpdate: NoAction)

  @@unique([sourceId, externalId])
  @@index([workspaceId])
  @@index([sourceId])
  @@index([parentScopeNodeId])
  @@index([workspaceId, selected])
  @@map("knowledge_sync_scope_nodes")
}

model KnowledgeSyncJob {
  jobId             String  @id
  workspaceId       String
  sourceId          String?
  status            String  @default("pending")
  requestedByUserId String?
  queuedAt          String
  startedAt         String?
  completedAt       String?
  failedAt          String?
  totalItems        Int?
  syncedItems       Int?
  failedItems       Int?
  errorCode         String?
  errorMessage      String?
  createdAt         String
  updatedAt         String

  dataSource KnowledgeDataSource?    @relation(fields: [sourceId], references: [sourceId], onDelete: Restrict, onUpdate: NoAction)
  events     KnowledgeSyncJobEvent[]

  @@index([workspaceId])
  @@index([sourceId])
  @@index([requestedByUserId])
  @@index([workspaceId, status])
  @@map("knowledge_sync_jobs")
}

model KnowledgeSyncJobEvent {
  syncJobEventId String  @id
  workspaceId    String
  jobId          String
  eventType      String
  status         String?
  message        String?
  errorCode      String?
  occurredAt     String
  createdAt      String

  syncJob KnowledgeSyncJob @relation(fields: [jobId], references: [jobId], onDelete: Restrict, onUpdate: NoAction)

  @@index([workspaceId])
  @@index([jobId])
  @@index([eventType])
  @@map("knowledge_sync_job_events")
}

model KnowledgeAccessGrant {
  knowledgeAccessGrantId String @id
  workspaceId            String
  documentId             String
  agentId                String
  status                 String @default("active")
  createdAt              String
  updatedAt              String

  document Document @relation(fields: [documentId], references: [documentId], onDelete: Restrict, onUpdate: NoAction)

  @@unique([workspaceId, documentId, agentId])
  @@index([workspaceId])
  @@index([documentId])
  @@index([agentId])
  @@index([workspaceId, status])
  @@map("knowledge_access_grants")
}

model Job {
  jobId       String  @id
  workspaceId String?
  userId      String?
  type        String
  status      String  @default("queued")
  createdAt   String
  updatedAt   String

  @@index([workspaceId])
  @@index([userId])
  @@index([status])
  @@map("jobs")
}

model PaymentMethod {
  id           String   @id @default(uuid())
  workspaceId  String
  type         String   // "card" | "momo" | "vnpay"
  brand        String?  // "visa" | "mastercard" etc.
  last4        String
  holder       String
  isDefault    Boolean  @default(false)
  gatewayToken String?  // Token thay thế số thẻ thô
  createdAt    String
  updatedAt    String

  @@index([workspaceId])
  @@map("payment_methods")
}
