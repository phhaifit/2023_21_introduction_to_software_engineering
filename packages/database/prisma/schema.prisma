generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agent {
  agentId      String @id
  workspaceId  String
  name         String
  role         String
  model        String
  instructions String
  status       String @default("enabled")
  createdAt    String
  updatedAt    String

  @@index([workspaceId])
  @@map("agents")
}

model Subscription {
  subscriptionId String  @id
  userId         String
  workspaceId    String?
  plan           String
  status         String
  expiresAt      String
  createdAt      String
  updatedAt      String

  @@index([userId])
  @@index([workspaceId])
  @@map("subscriptions")
}

model Transaction {
  transactionId  String @id
  subscriptionId String
  amount         Float
  currency       String @default("USD")
  status         String
  createdAt      String
  updatedAt      String

  @@index([subscriptionId])
  @@map("transactions")
}

model Workflow {
  workflowId    String   @id
  workspaceId   String
  name          String
  description   String?
  status        String   @default("Draft")
  triggerType   String   @default("manual")
  triggerConfig Json?
  createdAt     String
  updatedAt     String

  steps         WorkflowStep[]
  executions    WorkflowExecution[]

  @@index([workspaceId])
  @@map("workflows")
}

model WorkflowStep {
  stepId        String   @id
  workflowId    String
  name          String
  type          String
  order         Int
  config        Json
  createdAt     String
  updatedAt     String

  workflow      Workflow @relation(fields: [workflowId], references: [workflowId], onDelete: Cascade)
  logs          WorkflowStepLog[]

  @@index([workflowId])
  @@map("workflow_steps")
}

model WorkflowExecution {
  executionId   String   @id
  workflowId    String
  status        String
  triggeredBy   String
  startedAt     String
  completedAt   String?

  workflow      Workflow @relation(fields: [workflowId], references: [workflowId], onDelete: Cascade)
  stepLogs      WorkflowStepLog[]

  @@index([workflowId])
  @@map("workflow_executions")
}

model WorkflowStepLog {
  logId         String   @id
  executionId   String
  stepId        String
  status        String
  inputData     Json?
  outputData    Json?
  errorMsg      String?
  startedAt     String
  completedAt   String?

  execution     WorkflowExecution @relation(fields: [executionId], references: [executionId], onDelete: Cascade)
  step          WorkflowStep      @relation(fields: [stepId], references: [stepId], onDelete: Cascade)

  @@index([executionId])
  @@index([stepId])
  @@map("workflow_step_logs")
}
