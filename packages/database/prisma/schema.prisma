generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agent {
  agentId      String @id
  workspaceId  String
  name         String
  role         String
  model        String
  instructions String
  status       String @default("enabled")
  createdAt    String
  updatedAt    String

  @@index([workspaceId])
  @@map("agents")
}

model Subscription {
  subscriptionId String  @id
  userId         String
  workspaceId    String?
  plan           String
  status         String
  expiresAt      String
  createdAt      String
  updatedAt      String

  @@index([userId])
  @@index([workspaceId])
  @@map("subscriptions")
}

model Transaction {
  transactionId  String @id
  subscriptionId String
  amount         Float
  currency       String @default("USD")
  status         String
  createdAt      String
  updatedAt      String

  @@index([subscriptionId])
  @@map("transactions")
}

